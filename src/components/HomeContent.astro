---
import { tools } from "../data/tools";
import AboutMeContent from "./AboutMeContent.astro";
import FindMeLinks from "./FindMeLinks.astro";
---

<section class="home-hero">
	<AboutMeContent />
</section>
<section>
	<h1>I'm here</h1>
	<FindMeLinks />
</section>
<section>
	<h1>Tools</h1>
	<p>Miscellaneous tools built mostly with the help of LLMs.</p>
	<ul class="tool-summary-list">
		{
			tools.map((tool) => (
				<li>
					<p>
						<b>
							<a href={tool.url} target="_blank" rel="noreferrer">
								{tool.name}
							</a>
						</b>{" "}
						{tool.description}
					</p>
				</li>
			))
		}
	</ul>
	<p class="section-link"><a href="/tools/">Browse all tools →</a></p>
</section>
