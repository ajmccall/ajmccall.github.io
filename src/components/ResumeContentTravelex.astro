---
import FindMeLinks from "./FindMeLinks.astro";
import { Content as CurrentContent } from "../content/resume-current-travelex.md";
import { Content as WhoAmIContent } from "../content/resume-whoami.md";
import { Content as HistoryContent } from "../content/resume-history-travelex.md";
---

<section class="resume-section">
	<CurrentContent />
</section>

<section class="resume-section">
	<WhoAmIContent />
</section>

<section class="resume-section">
	<h1>I'm here</h1>
	<FindMeLinks />
</section>

<section class="resume-section">
	<h1>I've done</h1>
	<ul class="portfolio">
		<li>
			<img src="/images/portfolio/sainsburys.png" alt="Sainsbury's" />
		</li>
		<li>
			<img
				src="/images/portfolio/travelex.png"
				alt="Travelex Travel Money"
			/>
		</li>
		<li>
			<img
				src="/images/portfolio/AppIconAsda.png"
				alt="Asda Travel Money"
			/>
		</li>
		<li>
			<img src="/images/portfolio/trainline.jpg" alt="Trainline" />
		</li>
		<li>
			<img src="/images/portfolio/mtvtrax.png" alt="MTV Trax" />
		</li>
		<li>
			<img src="/images/portfolio/viou.jpeg" alt="VIOU" />
		</li>
		<li>
			<img src="/images/portfolio/jungle-spins.png" alt="Jungle Spins" />
		</li>
		<li>
			<img src="/images/portfolio/ocado.png" alt="Ocado" />
		</li>
	</ul>
</section>

<section class="resume-section">
	<HistoryContent />
</section>
