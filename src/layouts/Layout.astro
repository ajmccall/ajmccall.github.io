---
interface Props {
	title?: string;
	description?: string;
	canonical?: string;
}

const {
	title = 'Alasdair.md',
	description = "Alasdair's blog and resume",
	canonical = 'https://alasdair.md',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="og:site_name" content="Alasdair.md" />
		<link rel="canonical" href={canonical} />
		<meta name="twitter:url" content={canonical} />
		<meta name="og:url" content={canonical} />
		<title>{title}</title>
		<meta name="twitter:title" content={title} />
		<meta name="og:title" content={title} />
		<meta name="description" content={description} />
		<meta name="twitter:description" content={description} />
		<meta name="og:description" content={description} />
		<meta name="twitter:card" content="summary" />
		<link rel="stylesheet" href="/styles.css" type="text/css" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="shortcut icon" href="/images/favicon.png" type="image/png" />
		<link rel="alternate" href="/feed.rss" type="application/rss+xml" title="Subscribe to Alasdair.md" />
		<meta name="twitter:image" content="https://alasdair.md/images/profile.png" />
		<meta name="og:image" content="https://alasdair.md/images/profile.png" />
		<meta name="generator" content={Astro.generator} />
	</head>
	<body>
		<header>
			<div class="wrapper">
				<a href="/" class="site-name">Alasdair.md</a>
				<nav>
					<a href="/blog/">Blog</a>
					<a href="/tools/">Tools</a>
					<a href="/resume/">Resume</a>
				</nav>
				<div class="print-only header-contact">
					<span>https://alasdair.md</span>
					<span>alasdair.mccall@gmail.com</span>
				</div>
			</div>
		</header>
		<slot />
		<button class="theme-toggle" aria-label="Toggle dark/light mode"></button>
		<script>
			const html = document.documentElement;
			const btn = document.querySelector('.theme-toggle');
			const mq = window.matchMedia('(prefers-color-scheme: dark)');

			function systemTheme() {
				return mq.matches ? 'dark' : 'light';
			}

			function applyTheme(theme) {
				html.dataset.theme = theme;
				btn.textContent = theme === 'dark' ? '☀' : '☾';
			}

			const saved = localStorage.getItem('theme');
			applyTheme(saved || systemTheme());

			btn.addEventListener('click', () => {
				const next = html.dataset.theme === 'dark' ? 'light' : 'dark';
				localStorage.setItem('theme', next);
				applyTheme(next);
			});

			mq.addEventListener('change', () => {
				if (!localStorage.getItem('theme')) applyTheme(systemTheme());
			});
		</script>
	</body>
</html>
